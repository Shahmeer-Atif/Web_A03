# --- MongoDB ---
# Atlas connection string. Format: mongodb+srv://<user>:<pass>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# --- NextAuth (v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of the Next.js app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# --- Email (Gmail SMTP via Nodemailer) ---
# Use a Google App Password (NOT your account password)
# Setup: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=

# --- Real-time (Socket.io custom server) ---
# Port the standalone socket server listens on
SOCKET_PORT=4000
# Public URL the browser connects to (e.g. http://localhost:4000 in dev)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# --- Seed (initial admin) ---
# Used by `npm run seed` to create the first admin account
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
